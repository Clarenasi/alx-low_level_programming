#include "main.h"

/**
* convert_day - converts day of month to day of year, without accounting
* for leap year
* @month: month in number format
* @day: day of month
* Return: day of year
*/

int convert_day(int month, int day)
{
	switch (month)
	{
		case 2:
			day = 31 + day;
			break;
		case 3:
			if (day == 59)
			{
				day = 59 + day;
			}
			else
			{
				day = 60 + day;
			}
			break;
		case 4:
			if (day == 90)
			{
				day = 90 + day;
			}
			else
			{
				day = 91 + day;
			}
			break;
		case 5:
			if (day == 120)
			{
				day = 120 + day;
			}
			else
			{
				day = 121 + day;
			}
			break;
		case 6:
			if (day == 152)
			{
				day = 151 + day;
			}
			else
			{
				day = 152 + day;
			}
			break;
		case 7:
			if (day == 181)
			{
				day = 181 + day;
			}
			else
			{
				day = 182 + day;
			}
			break;
		case 8:
			if (day == 212)
			{
				day = 212 + day;
			}
			else
			{
				day = 213 + day;
			}
			break;
		case 9:
			if (day == 243)
			{
				day = 243 + day;
			}
			else
			{
				day = 244 + day;
			}
			break;
		case 10:
			if (day == 273)
			{
				day = 273 + day;
			}
			else
			{
				day = 274 = day;
			}
			break;
		case 11:
			if (day == 304)
			{
				day = 304 + day;
			}
			else
			{
				day = 305 + day;
			}
			break;
		case 12:
			if (day == 334)
			{
				day = 334 + day;
			}
			else
			{
				day = 335 + day;
			}
			break;
		default:
			break;
	}
	return (day);
}
